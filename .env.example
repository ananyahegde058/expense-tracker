# ─── Security ────────────────────────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=REPLACE_WITH_YOUR_SECRET_KEY
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (default, fine for small deployments)
DATABASE_URL=sqlite:///./expenses.db
# For PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://user:password@localhost/expensedb

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# For Gmail: use an App Password (not your normal password)
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=your-email@gmail.com

# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME=Smart Expense Tracker
# Your deployed URL — used in email links
APP_BASE_URL=https://your-app-name.onrender.com

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# ALLOWED_ORIGINS=https://your-app-name.onrender.com
